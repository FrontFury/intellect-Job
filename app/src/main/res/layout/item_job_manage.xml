<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="16dp"
    android:layout_marginVertical="8dp"
    app:cardCornerRadius="14dp"
    app:cardElevation="3dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- Top Row: Company Icon, Titles, and Status -->
        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <!-- Company Logo Placeholder -->
            <ImageView
                android:id="@+id/ivCompanyLogo"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:layout_alignParentStart="true"
                android:layout_centerVertical="true"
                android:background="#1A5B3294"
                android:padding="8dp"
                android:src="@android:drawable/ic_menu_myplaces"
                app:tint="#5B3294" />

            <!-- Title and Company -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_centerVertical="true"
                android:layout_marginHorizontal="12dp"
                android:layout_toStartOf="@id/tvJobStatus"
                android:layout_toEndOf="@id/ivCompanyLogo"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/tvJobTitle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:ellipsize="end"
                    android:maxLines="1"
                    android:text="Senior Android Developer"
                    android:textColor="#111111"
                    android:textSize="16sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tvCompanyName"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="2dp"
                    android:text="TechCorp Solutions Ltd."
                    android:textColor="#7000CC"
                    android:textStyle="bold"
                    android:textSize="13sp" />
            </LinearLayout>

            <!-- Active / Inactive Status Tag -->
            <TextView
                android:id="@+id/tvJobStatus"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_alignParentEnd="true"
                android:layout_centerVertical="true"
                android:background="#122E7D32"
                android:paddingHorizontal="10dp"
                android:paddingVertical="4dp"
                android:text="Active"
                android:textColor="#2E7D32"
                android:textSize="11sp"
                android:textStyle="bold" />
        </RelativeLayout>

        <!-- Divider -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginVertical="12dp"
            android:background="#E0E0E0" />

        <!-- Middle Row: Job Metadata (Type, Location, Salary) -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/tvJobType"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Full-Time"
                android:textColor="#444444"
                android:textSize="12sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:paddingHorizontal="6dp"
                android:text="•"
                android:textColor="#888888" />

            <TextView
                android:id="@+id/tvJobLocation"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Remote"
                android:textColor="#444444"
                android:textSize="12sp" />

            <View
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:layout_weight="1" />

            <!-- Salary Info -->
            <TextView
                android:id="@+id/tvSalary"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="$80k - $100k/yr"
                android:textColor="#5B3294"
                android:textSize="13sp"
                android:textStyle="bold" />
        </LinearLayout>

        <!-- Bottom Row: Applicants, Date Posted & Action Icons -->
        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp">

            <!-- Applicants Tag & Posted Date Info -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_alignParentStart="true"
                android:layout_centerVertical="true"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/tvVacancies"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:background="#1A5B3294"
                    android:paddingHorizontal="10dp"
                    android:paddingVertical="4dp"
                    android:text="4 Vacancies"
                    android:textColor="#5B3294"
                    android:textSize="12sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tvPostedDate"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:text="Posted: 3 days ago"
                    android:textColor="#888888"
                    android:textSize="11sp" />
            </LinearLayout>

            <!-- Action Buttons Container (Update & Delete) -->
            <LinearLayout
                android:id="@+id/actionButtons"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_alignParentEnd="true"
                android:layout_centerVertical="true"
                android:orientation="horizontal">

                <!-- Update Button -->
                <ImageView
                    android:id="@+id/btnUpdate"
                    android:layout_width="38dp"
                    android:layout_height="38dp"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:clickable="true"
                    android:contentDescription="Update Job"
                    android:focusable="true"
                    android:padding="8dp"
                    android:src="@android:drawable/ic_menu_edit"
                    app:tint="#5B3294" />

                <!-- Delete Button -->
                <ImageView
                    android:id="@+id/btnDelete"
                    android:layout_width="38dp"
                    android:layout_height="38dp"
                    android:layout_marginStart="8dp"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:clickable="true"
                    android:contentDescription="Delete Job"
                    android:focusable="true"
                    android:padding="8dp"
                    android:src="@android:drawable/ic_menu_delete"
                    app:tint="#D32F2F" />
            </LinearLayout>
        </RelativeLayout>

    </LinearLayout>
</androidx.cardview.widget.CardView>